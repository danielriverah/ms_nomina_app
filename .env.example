SECRET_KEY=pon_una_clave_larga_y_segura

# Si prefieres una sola cadena de conexión, usa DATABASE_URL y omite el bloque MySQL.
# DATABASE_URL=mysql+pymysql://usuario:password@host:3306/nomina

# O bien usa variables separadas para MySQL.
DB_DIALECT=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=nomina
DB_USER=usuario
DB_PASSWORD=pon_tu_password
DB_DRIVER=pymysql

# Opcional: si quieres forzar SQLite local, define esto.
# SQLITE_URL=sqlite:///nomina.db
